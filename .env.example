# ===== Backend =====
# Local dev: sqlite+aiosqlite:///./subadash.db
# Render (with persistent disk): sqlite+aiosqlite:////var/data/subadash.db
# Supabase (Phase 2): postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./subadash.db

# LLM (primary)
ANALYZER_PROVIDER=claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_ANALYZE=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_CHAT=claude-haiku-4-5-20251001

# Optional alt providers
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1
# Free-tier fallbacks (used automatically when Anthropic credits run out)
GROQ_API_KEY=
GEMINI_API_KEY=
# Comma-separated fallback order; first available provider wins
LLM_FALLBACK_CHAIN=claude,groq,gemini

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256

# App
# Comma-separated list of allowed origins (prod + dev).
# e.g. https://subadash.pages.dev,http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:3000
ENVIRONMENT=development
MAX_UPLOAD_MB=25

# Render injects PORT automatically; local dev falls back to 8002
# PORT=8002

# ===== Phase 2 (R2 / Supabase) =====
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=subadash-uploads

# ===== Sandbox (Track B) =====
# SANDBOX_MODE=subprocess
# SANDBOX_TIMEOUT_SECONDS=10
# SANDBOX_MEMORY_MB=256
