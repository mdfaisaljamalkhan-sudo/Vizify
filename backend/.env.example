# Database
DATABASE_URL=sqlite+aiosqlite:///./subadash.db

# Security
JWT_SECRET=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256

# LLM Analyzer Provider (claude, openai, deepseek, ollama)
ANALYZER_PROVIDER=claude

# Claude AI
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
OPENAI_API_KEY=sk-...

# Deepseek (free alternative)
DEEPSEEK_API_KEY=sk-...

# Ollama (local free models)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Analysis Settings
MAX_ANALYSIS_INPUT_TOKENS=8000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# File Upload
MAX_UPLOAD_SIZE_MB=25
ALLOWED_EXTENSIONS=["csv","xlsx","xls","docx","pdf","json"]

# App
ENVIRONMENT=development
DEBUG=true
